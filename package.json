{
  "name": "todo-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "cap:init": "npx cap init TaskMaster com.esga.taskmaster --web-dir=dist/todo-app",
    "cap:sync": "npx cap sync",
